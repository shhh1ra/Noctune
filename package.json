{
  "name": "noctune",
  "version": "1.2.0",
  "private": true,
  "description": "Lightweight custom Spotify desktop client with Web Playback SDK and Connect fallback.",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "tauri:dev": "tauri dev",
    "web:dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "dist:win": "tauri build --bundles nsis",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint . --ext ts,tsx --max-warnings 0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@11.4.1"
}
