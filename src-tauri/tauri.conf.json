{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noctune",
  "version": "0.1.0",
  "identifier": "dev.shhh1ra.noctune",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Noctune",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "backgroundColor": "#0b0d10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Music",
    "shortDescription": "Noctune",
    "longDescription": "Lightweight custom Spotify desktop client with React UI, Spotify Web API, Web Playback SDK, and Connect fallback.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "perMachine"
      }
    }
  }
}
